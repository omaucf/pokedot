{
  "name": "@pokedot/docs",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "[ ! -d .nuxt ] && nuxt prepare || true",
    "start": "node .output/server/index.mjs",
    "dev": "dotenv-run -- nuxt dev",
    "build": "nuxt build",
    "typecheck": "nuxt typecheck --noEmit",
    "clean": "git clean -xdf .nuxt .output .turbo node_modules"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.100",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/ui": "^4.6.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mdc": "^0.21.0",
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "vue-tsc": "^3.2.6"
  }
}
